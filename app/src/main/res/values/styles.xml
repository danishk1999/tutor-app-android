<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom style for weekdays (Mon, Tue, etc.) in the calendar -->
    <style name="CalendarWeekDayText">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#757575</item> <!-- Light gray color -->
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:statusBarColor">@color/purple</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Custom style for calendar dates (1, 2, 3, etc.) -->
    <style name="CalendarDateText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#000000</item> <!-- Black color -->
    </style>
</resources>
